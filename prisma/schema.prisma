generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Template {
  id          String   @id @default(cuid())
  name        String
  description String?
  filename    String
  storedPath  String
  publicUrl   String
  widthPx     Int      @default(1920)
  heightPx    Int      @default(1080)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  wallpapers Wallpaper[]
}

model Wallpaper {
  id           String   @id @default(cuid())
  comarcaName  String
  wifiSsid     String
  wifiPassword String
  wifiSecurity String   @default("WPA")
  qrContent    String
  storedPath   String
  publicUrl    String
  templateId   String
  template     Template @relation(fields: [templateId], references: [id])
  createdAt    DateTime @default(now())

  @@index([templateId])
  @@index([createdAt])
}
